<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chess</title>
    <link rel="stylesheet" href="/css/chessboard.css" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('partials/header', { userId }) %>
    <main class="main-content">
      <section class="home-page">
        <div class="hero-copy">
          <span class="eyebrow">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m12 3 2.4 4.9 5.4.8-3.9 3.8.9 5.4-4.8-2.5-4.8 2.5.9-5.4-3.9-3.8 5.4-.8L12 3Z" />
            </svg>
            Pink tactical arena
          </span>
          <h1>Play chess in blush mode.</h1>
          <p>Start a clean, focused match against the AI or play local two-player with a board that feels soft, sharp, and deliberately designed.</p>
          <div class="home-actions">
            <a href="/game" class="btn btn-primary">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="6 3 20 12 6 21 6 3" />
              </svg>
              Play vs AI
            </a>
            <% if (!userId) { %>
              <a href="/auth/register" class="btn btn-secondary">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M19 8v6" />
                  <path d="M22 11h-6" />
                </svg>
                Create Account
              </a>
            <% } %>
          </div>
        </div>

        <div class="hero-board-card" aria-hidden="true">
          <svg class="hero-board-svg" viewBox="0 0 420 520" role="img">
            <defs>
              <linearGradient id="heroFrame" x1="0" x2="1" y1="0" y2="1">
                <stop offset="0" stop-color="#ffffff" />
                <stop offset="1" stop-color="#ffd7e7" />
              </linearGradient>
              <linearGradient id="heroPiece" x1="0" x2="1" y1="0" y2="1">
                <stop offset="0" stop-color="#be2768" />
                <stop offset="1" stop-color="#ff8cba" />
              </linearGradient>
              <filter id="heroShadow" x="-20%" y="-20%" width="140%" height="140%">
                <feDropShadow dx="0" dy="18" stdDeviation="16" flood-color="#8d1c4d" flood-opacity="0.22" />
              </filter>
            </defs>
            <rect x="30" y="68" width="360" height="360" rx="12" fill="url(#heroFrame)" filter="url(#heroShadow)" />
            <g transform="translate(50 88)">
              <% for (let row = 0; row < 8; row++) { %>
                <% for (let col = 0; col < 8; col++) { %>
                  <rect x="<%= col * 40 %>" y="<%= row * 40 %>" width="40" height="40" fill="<%= (row + col) % 2 === 0 ? '#fff1f7' : '#f2a0c2' %>" />
                <% } %>
              <% } %>
              <rect x="160" y="80" width="40" height="40" fill="#ffc4dc" opacity="0.9" />
              <rect x="200" y="120" width="40" height="40" fill="#ffc4dc" opacity="0.9" />
              <circle cx="220" cy="140" r="8" fill="#be2768" opacity="0.72" />
              <circle cx="180" cy="100" r="16" fill="none" stroke="#be2768" stroke-width="4" opacity="0.62" />
            </g>
            <g fill="url(#heroPiece)">
              <path d="M188 312h44l-5 38h-34l-5-38Z" />
              <path d="M174 364h72l-10 24h-52l-10-24Z" />
              <path d="M164 392h92v26h-92z" />
              <path d="M185 204a25 25 0 1 1 50 0 25 25 0 0 1-50 0Z" />
              <path d="M178 238h64l16 58h-96l16-58Z" />
            </g>
            <path d="M70 458c54 22 111 32 171 30 42-1 78-8 109-21" fill="none" stroke="#f66fa4" stroke-width="10" stroke-linecap="round" opacity="0.32" />
          </svg>
        </div>
      </section>
    </main>
  </body>
</html>
