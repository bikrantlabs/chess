<header class="navbar">
  <div class="navbar-inner">
    <a href="/" class="logo" aria-label="Chess home">
      <span class="logo-mark" aria-hidden="true">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 21h8" />
          <path d="M12 17v4" />
          <path d="M7 17h10l-1.2-5.2A4 4 0 0 0 12 9a4 4 0 0 0-3.8 2.8L7 17Z" />
          <path d="M9 6a3 3 0 1 0 6 0 3 3 0 0 0-6 0Z" />
        </svg>
      </span>
      <span class="logo-text">Chess</span>
    </a>
    <nav class="nav-links">
      <a href="/">Home</a>
      <a href="/game">Play</a>
      <% if (typeof userId !== 'undefined' && userId) { %>
        <a href="/game">Dashboard</a>
        <form method="POST" action="/auth/logout" class="inline-form">
          <button type="submit" class="link-btn">Logout</button>
        </form>
      <% } else { %>
        <a href="/auth/login">Login</a>
        <a href="/auth/register">Register</a>
      <% } %>
    </nav>
  </div>
</header>
